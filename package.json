{
  "name": "homesync",
  "version": "1.0.0",
  "private": true,
  "description": "Predictive Neighborhood Maintenance Platform",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "npm run dev:server & npm run dev:client",
    "setup": "bash scripts/setup.sh",
    "migrate": "cd database && npx knex migrate:latest",
    "seed": "cd database && npx knex seed:run",
    "build": "npm run build --workspace=client"
  },
  "devDependencies": {
    "puppeteer": "^24.40.0"
  }
}
