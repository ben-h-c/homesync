# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_PATH=./database/homesync.db

# JWT Auth (REQUIRED in production — must be 32+ chars)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:5173

# App URLs
CLIENT_URL=http://localhost:5173

# Resend (Email) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=hello@homesynctoday.com
FROM_NAME=HomeSync

# Stripe (Payments) — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxx

# Anthropic (AI) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Frontend (set in client/.env)
VITE_API_URL=http://localhost:3001/api
